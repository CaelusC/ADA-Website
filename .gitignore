# See https://help.github.com/articles/ignoring-files for more about ignoring files.

# Ignore bundler config.
/.bundle

# Ignore all environment files (except templates).
.env*
!.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/pids/
!/tmp/pids/.keep
!/tmp/storage/
!/tmp/storage/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and auto-generated in test).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# Ignore assets built by asset pipeline.
/public/assets
/public/vite-dev
/public/vite-test

# Ignore master key for decrypting credentials and more.
/config/master.key
/config/credentials/*.key

# Node
node_modules/

# macOS
.DS_Store
